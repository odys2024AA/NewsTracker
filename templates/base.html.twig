<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <icon rel="shortcut icon" href="./favicon.ico">

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}

    </head>
    <body class="h-screen w-screen">
        <div class="bg-black min-h-screen w-full text-gray-200">
            {% block body %}{% endblock %}
        </div>
        
    </body>
</html>