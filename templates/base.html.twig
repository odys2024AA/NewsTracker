<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <icon rel="shortcut icon" href="./favicon.ico">

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>


        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}

    </head>
    <body class="bg-bgdefault min-h-screen text-textcustom">
            <div class="">
                <button data-controller="theme" data-action="click->theme#toggle">
                    Switch Theme
                </button>
            </div>
            {% block body %}{% endblock %}
        
    </body>
</html>